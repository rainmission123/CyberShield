<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_matrix_panel"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CYBERSHIELD MENU"
            android:textAlignment="center"
            android:textColor="#00FF41"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="#00FF41"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a shield action"
            android:textAlignment="center"
            android:textColor="#A9FFB0"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/menuScan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⌕  Scan Current Link"
            android:textAllCaps="false"
            android:textColor="#D5FFD9"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item" />

        <Button
            android:id="@+id/menuHistory"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="◷  View Scan History"
            android:textAllCaps="false"
            android:textColor="#00FF41"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/menuRealtime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="▣  Enable Realtime Protection"
            android:textAllCaps="false"
            android:textColor="#FF8D87"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item_danger"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/menuDefault"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="▣  Set as Link Protector"
            android:textAllCaps="false"
            android:textColor="#D5FFD9"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/menuClear"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="×  Clear Current Scan"
            android:textAllCaps="false"
            android:textColor="#A9FFB0"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/menuAbout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="i  About CyberShield"
            android:textAllCaps="false"
            android:textColor="#A9FFB0"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</FrameLayout>
