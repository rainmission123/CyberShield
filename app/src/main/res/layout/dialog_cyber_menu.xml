<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_matrix_panel"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MENU"
            android:textAlignment="center"
            android:textColor="#00FF41"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="#00FF41"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CyberShield controls"
            android:textAlignment="center"
            android:textColor="#A9FFB0"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/menuHistory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="View Scan History"
            android:textColor="#00FF41"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/menuRealtime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Realtime Protection"
            android:textColor="#FF8D87"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item_danger"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/menuDefault"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Set as Link Protector"
            android:textColor="#D5FFD9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/menuAbout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="About CyberShield"
            android:textColor="#A9FFB0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_matrix_menu_item"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
